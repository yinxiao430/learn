package practice;

import java.util.Scanner;
public class Test4 {

	public static void main(String[] args) {
		 Scanner scan = new Scanner(System.in);
	        //在此输入您的代码...
		 int N=scan.nextInt();
		 scan.nextLine();
		 char [][]p=new char [N][N];
		 for (int i = 0; i < N; i++) {		
				 String line=scan.nextLine();
				p[i]=line.toCharArray();						
		}
		 int count=0;
		 boolean [][]visited=new boolean [N][N];
		 for (int i = 0; i < N; i++) {
			 for (int j = 0; j < N; j++) {
				if(p[i][j]=='#'&&visited[i][j]==false) {
					count++;
					dfs(p, visited, j, i, N);
				}
			}
			
		}
		 System.out.println(count);
		 
	     scan.close();

	}
	static int []fangxiang_x= {1,0,-1,0};
	static int []fangxiang_y= {0,1,0,-1};
	public static void dfs(char p[][],boolean visited[][],int x,int y,int N) {
		if(x>=N||x<0||y>=N||y<0||p[y][x]!='#'||visited[y][x]==true) {		
			return ;
		}
		visited[y][x] = true;
		for (int i = 0; i < 4; i++) {
			int tx=x+fangxiang_x[i];
			int ty=y+fangxiang_y[i];
			dfs(p, visited, tx, ty, N);
			
		}		
		return;
	}

}
