package lanqiaobei14;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.Scanner;


public abstract class Test6 {
private static int N;
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner scan = new Scanner(System.in);
        //在此输入您的代码...
		N=scan.nextInt();
		int A[]=new int [N];
		ArrayList<Integer> AA=new ArrayList <Integer> ();
		for (int i = 0; i < N; i++) {
			A[i]=scan.nextInt();
		}
		Arrays.sort(A);
		//System.out.println(Arrays.toString(A));
		revered(A);
		for (int i = 0; i < N; i++) {
			AA.add(A[i]);
		}
		ArrayList<Integer> pay=new ArrayList<Integer>();
		//System.out.println(Arrays.toString(A));
		for (int i = 0; i < N; i++) {
			pay.add(AA.getFirst());
			AA.remove(0);
			if (pay.size()%2==0) {
				for (int j = 0; j < AA.size(); j++) {
					if (AA.get(j)<=pay.getLast()/2) {
						AA.remove(j);
					}
				}
			}
		}
	int count=0;
	for (int i = 0; i < pay.size(); i++) {
		count+=pay.get(i);
	}	
	System.out.println(count);
        scan.close();
	}
    public static void revered (int a[]) {
		for (int i = 0; i < N/2; i++) {
			int temp=a[i];
			a[i]=a[N-1-i];
			a[N-1-i]=temp;
		}
	}
}
