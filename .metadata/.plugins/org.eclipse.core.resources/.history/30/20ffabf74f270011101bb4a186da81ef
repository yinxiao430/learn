package practice;

import java.util.ArrayList;
import java.util.Scanner;

public class Test15 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
        	Scanner scan = new Scanner(System.in);
		        //在此输入您的代码...
        	double n=scan.nextInt();
        	ArrayList<Double> fblaxi=new ArrayList<Double>();
        	double temp=n;
        	while (true) {
				double a=temp%10;
				fblaxi.add(a);
				temp=temp/10;
				if (temp==0) {
					break;
				}
			}
        	for (int i = 0; i < fblaxi.size(); i++) {
				System.out.println(fblaxi.get(i));
			}
	        scan.close();
	}

}
