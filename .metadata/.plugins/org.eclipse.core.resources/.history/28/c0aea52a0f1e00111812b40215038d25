package practice;

import java.util.Scanner;

public class Test8 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		 Scanner scan = new Scanner(System.in);
	        //在此输入您的代码...
		 int h1=scan.nextInt();
		 int h2=scan.nextInt();
		 int []hang1=new int[h1];
		 int []hang2=new int[h2];
		 for (int i = 0; i < h1; i++) {
			hang1[i]=scan.nextInt();
		}
		 for (int i = 0; i < h2; i++) {
			hang2[i]=scan.nextInt();
		}
		 int count=0;
		 for (int i = 0; i < h1; i++) {
			 for (int j = 0; j < h2; j++) {
				int s=hang1[i]+hang2[j];
				int nm=h1+h2;
				if ((s<nm)&&(iszhishu(s))) {
					count++;
				}
			}		
		}
		 System.out.println(count);
	     scan.close();
	}
	public static boolean iszhishu(int s) {
		if(s<2) return false;
		if(s==2) return true;
		for (int i = 3; i < Math.sqrt(s); i+=2) {
			if(s%i==0)return false;
		}
		return true;
	}
}
