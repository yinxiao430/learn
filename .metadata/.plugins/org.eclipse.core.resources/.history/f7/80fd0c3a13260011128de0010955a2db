public class Test13 {
	 public static void main(String[] args) {
	     Scanner scan = new Scanner(System.in);
	     //在此输入您的代码...
	     int n=scan.nextInt();
	     int k=scan.nextInt();
	     int num[]=new int[n];
	     for (int i = 0; i < n; i++) {
			num[i]=scan.nextInt();
		}
	     int []num_mi=new int[n];
	     for (int i = 0; i < n; i++) {
			num_mi[i]=K(num[i]);
		}
	     System.out.println(Arrays.toString(num_mi));
	     scan.close();
	 }
 
	 public static int K(int num) {
		 int a=num;
		  if (a==0) {
				return 0;
			}
		 int count=0;	 
		 while (a%2==0) {
			count++;
			a=a/2;
		}
		 return count;
	 }
}
