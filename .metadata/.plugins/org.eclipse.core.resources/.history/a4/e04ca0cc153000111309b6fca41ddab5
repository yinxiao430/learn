package lanqiaobei14;

import java.util.ArrayList;
import java.util.Scanner;

public class Test2 {
	 public static void main(String[] args) {
	        Scanner scan = new Scanner(System.in);
	        //在此输入您的代码...
	        int T=scan.nextInt();
	        ArrayList<long []> g=new ArrayList<long []>();
	        
	        for (int i = 0; i < T; i++) {
				int N=scan.nextInt();
				long A[]=new long[N+2];
				long sum=0;
				long count=0;
				for (int j = 0; j < N; j++) {
					A[i]=scan.nextInt();
					sum+=A[i];
					if (sum%2==0) {
						count++;
					}
				}
				A[N]=sum;
				A[N+1]=count;
				g.add(A);
			}
	        for (int i = 0; i < T; i++) {
				long A[]=g.get(i);
				long s=A[A.length-1];
				System.out.println(s);
				long count=A[A.length-2];
				System.out.println(count);
				if (s%2!=0) {
					System.out.println(0);
				}
				else {
					long re=X_2(count);
					long mo=1000000007;
					long result=re%mo;							 
					System.out.println(result);
				}
				
			}
	        scan.close();
	    }
	 public static long X_2(long count) {	
			int a=1<<count;
			return a;
		}
}
