import java.util.Scanner;
public class Test4 {

	public static void main(String[] args) {
		 Scanner scan = new Scanner(System.in);
	        //在此输入您的代码...
		 int N=scan.nextInt();
		 scan.nextLine();
		 char [][]p=new char [N][N];
		 char [][] tempp=new char[N][N];
		 for (int i = 0; i < N; i++) {		
				 String line=scan.nextLine();
				p[i]=line.toCharArray();
		}
		 for (int i = 0; i < N; i++) {
	            for (int j = 0; j < N; j++) {
	               tempp[i][j] = p[i][j];
	            }
	        }
		 
		 int count1=daoyunum(p, N);
		 System.out.println(count1);
		 isEdge(tempp, N);
		 for (int i = 0; i < N; i++) {
			 for (int j = 0; j < N; j++) {
				if (tempp[i][j]=='!') {
					tempp[i][j]='.';
				}
			}
			
		}
