	public static void DFS(int G[][],int x,int y,boolean visited[][]) {
		if(x>=N||x<0||y>=N||y<0||G[x][y]!=1||visited[x][y]==true) {		
			return ;
		}
		visited[x][y]=true;
		for (int i = 0; i < 4; i++) {
			int tx=x+x_dire[i];
			int ty=y+y_dire[i];
			if (tx<=N||tx>0||ty<=N||ty>0||G[tx][ty]==1||visited[tx][ty]==false) {
				visited[tx][ty]=true;
				DFS(G, tx, ty,visited);
			}
		}
		
	}
