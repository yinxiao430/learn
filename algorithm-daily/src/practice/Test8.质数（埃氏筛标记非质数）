// 1. 定义质数表和最大范围（非static代码块，而是成员变量）
private static boolean[] isPrime;
private static final int MAX = 200000;

// 2. 封装预处理方法（主动调用）
private static void initPrime() {
    // 初始化数组（这里才分配内存）
    isPrime = new boolean[MAX + 1];
    // 步骤1：默认所有数是质数（0/1除外）
    for (int i = 2; i <= MAX; i++) {
        isPrime[i] = true;
    }
    // 步骤2：埃氏筛标记非质数
    for (int i = 2; i * i <= MAX; i++) {
        if (isPrime[i]) {
            for (int j = i * i; j <= MAX; j += i) {
                isPrime[j] = false;
            }
        }
    }
}

